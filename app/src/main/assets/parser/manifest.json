{
  "manifest_version": 2,
  "version": "4.2",
  "browser_specific_settings": {
    "gecko": {
      "id": "parser@solarized.dev"
    }
  },
  "name": "Video parser",
  "description": "Parses media URLs from Vimeo, Twitter/X, Instagram, Kick, Twitch, Dailymotion, Apple Podcasts, and TikTok",
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.tiktok.com/*",
        "*://m.tiktok.com/*"
      ],
      "js": [
        "tiktok-content.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    "tiktok-inject.js"
  ],
  "permissions": [
    "nativeMessaging",
    "nativeMessagingFromContent",
    "geckoViewAddons",
    "tabs",
    "cookies",
    "storage",
    "webRequest",
    "webRequestBlocking",
    "webNavigation",
    "*://*.instagram.com/*",
    "*://*.x.com/*",
    "*://*.twitter.com/*",
    "*://*.vimeo.com/*",
    "*://*.kick.com/*",
    "*://*.twitch.tv/*",
    "*://*.ttvnw.net/*",
    "*://gql.twitch.tv/*",
    "*://clips.twitch.tv/*",
    "*://*.dailymotion.com/*",
    "*://geo.dailymotion.com/*",
    "*://*.dmcdn.net/*",
    "*://podcasts.apple.com/*",
    "*://amp-api.podcasts.apple.com/*",
    "*://amp-api-edge.podcasts.apple.com/*",
    "*://itunes.apple.com/*",
    "*://*.tiktok.com/*"
  ]
}