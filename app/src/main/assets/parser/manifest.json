{
  "manifest_version": 2,
  "version": "1.7",
  "browser_specific_settings": {
    "gecko": {
      "id": "parser@solarized.dev"
    }
  },
  "name": "Video parser",
  "description": "Parses media URLs from Vimeo, Twitter/X, Instagram, Kick, Twitch, Dailymotion, and Apple Podcasts",
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "permissions": [
    "nativeMessaging",
    "nativeMessagingFromContent",
    "geckoViewAddons",
    "tabs",
    "cookies",
    "storage",
    "webRequest",
    "webRequestBlocking",
    "webNavigation",
    "*://*.instagram.com/*",
    "*://*.x.com/*",
    "*://*.twitter.com/*",
    "*://*.vimeo.com/*",
    "*://*.kick.com/*",
    "*://*.twitch.tv/*",
    "*://*.ttvnw.net/*",
    "*://gql.twitch.tv/*",
    "*://clips.twitch.tv/*",
    "*://*.dailymotion.com/*",
    "*://geo.dailymotion.com/*",
    "*://*.dmcdn.net/*",
    "*://podcasts.apple.com/*",
    "*://amp-api.podcasts.apple.com/*",
    "*://amp-api-edge.podcasts.apple.com/*",
    "*://itunes.apple.com/*"
  ]
}