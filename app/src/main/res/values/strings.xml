    <!-- Trailing-action label on the home recent-downloads card. Kept
         short so it fits next to the section title on narrow phones
         even in longer Romance / Slavic locales. -->
    <!-- Section header on the home media strip — shown while a tab
         is actively producing audio / video. Pairs with
         home_media_paused for the paused-but-spotlit state so the
         user can resume from the card. -->
    <string name="home_media_playing">Playing</string>
    <string name="home_media_paused">Paused</string>
    <!-- Section header on the home active-download strip when there
         are more downloads in flight than the single one the card
         shows. %1$d is the count of additional downloads beyond the
         visible row. Whole string is uppercased by the view. -->
    <string name="home_active_downloads_more">Downloading · +%1$d more</string>
    <!-- Subtitle on the home Downloads card. Combines the file-count
         plural with a readable byte size — '150 files saved · 2.4 GB'.
         %1$s is the plural (home_downloads_file_count), %2$s is the
         size string (Utils.readableFileSize). -->
    <string name="home_downloads_subtitle_with_size">%1$s · %2$s</string>
    <!-- Header label for the supported-sites chip strip inside the
         onboarding card. Frames the brand chips as 'we test against
         these'. Tap a chip → visits the site. -->
