<resources>
    <declare-styleable name="FullscreenAttrs">
        <attr name="fullscreenBackgroundColor" format="color" />
        <attr name="fullscreenTextColor" format="color" />
    </declare-styleable>
    <declare-styleable name="LoginPanelTextInputLayout">
        <attr name="InputLayoutErrorTextColor" format="reference"/>
        <attr name="InputLayoutErrorIconColor" format="reference"/>
        <attr name="PromptLoginEditTextCursorColor" format="reference"/>
    </declare-styleable>
    <declare-styleable name="StateClickableImageButton">
        <attr name="stateClickable" format="boolean" />
    </declare-styleable>
    <declare-styleable name="TabsBrowserButton">
        <attr name="tabBackgroundDrawable" format="integer" />
        <attr name="tabTextColor" format="color" />
    </declare-styleable>
    <declare-styleable name="BottomNavigationBar">
        <!-- When true, the middle slot is laid out INVISIBLE — preserves the
             5-cell weight balance while leaving room for an externally-anchored
             FAB to sit over it. Used by the browser layout; home shows the
             bookmarks/search action in the slot instead. -->
        <attr name="hideMiddleSlot" format="boolean" />
    </declare-styleable>
    <declare-styleable name="GeckoToolbar">
        <attr name="enableHome" format="boolean" />
    </declare-styleable>
    <declare-styleable name="ExpandableButton">
        <attr name="expandableText" format="string" />
        <attr name="expandableChildView" format="reference" />
        <attr name="expandableIcon" format="reference" />
    </declare-styleable>
    <declare-styleable name="AspectRatioConstraintLayout">
        <!-- width / height — e.g. 0.75 for 3:4 (taller than wide). -->
        <attr name="aspectRatio" format="float" />
    </declare-styleable>
    <!-- Shared maxHeight attribute. Applied by any view in
         com.solarized.firedown.ui that needs to cap its measured
         height while keeping wrap_content semantics below the cap
         (currently MaxHeightRecyclerView). -->
    <declare-styleable name="MaxHeightView">
        <attr name="maxHeight" format="dimension" />
    </declare-styleable>

    <!-- Set true on themes that already use the incognito palette
         (e.g. Theme.FireDown.Vault) so BaseActivity skips the AMOLED
         true-black overlay for them. Without this guard the overlay's
         pure-black surfaces clobber the incognito purple. -->
    <attr name="isIncognitoTheme" format="boolean" />

    <!-- Fill color for the rounded-square tile that frames identity
         favicons on bottom sheets (bg_popup_favicon). Standard sheets
         pick a surfaceVariant tone (different tonal family from the
         sheet bg → reads as "tile behind icon"); the incognito sheet
         theme overrides this with a purple-family container tone so
         the tile doesn't clash with the incognito sheet's purple bg. -->
    <attr name="popupFaviconBackgroundColor" format="color|reference" />
</resources>