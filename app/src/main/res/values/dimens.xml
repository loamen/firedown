    <!-- Incognito-in-progress banner bottom margin. The banner is always
         followed by the first date header (fragment_item_header), which has a
         fixed 20dp paddingTop. Negative margin cancels most of it so the gap
         BELOW the banner (~8dp net) matches the gap ABOVE it (list_spacing),
         instead of the lopsided 6 + 20 = 26dp. -->
    <dimen name="incognito_banner_margin_bottom">-12dp</dimen>
