    <!--
        Browser popup contents used to live as three parallel arrays
        (ids / labels / icons) consumed by a RecyclerView adapter. The
        popup is now a static layout of MaterialCard sections in
        fragment_dialog_browser_popup.xml — the section grouping is too
        structurally meaningful to flatten back into a string array, and
        the click dispatch happens directly on each row's view id.
    -->


    <!--
        Home popup contents used to live as parallel string/icon arrays
        consumed by a RecyclerView adapter that dispatched the icon
        drawable resource id as the OptionEntity id. The popup is now a
        static layout of MaterialCard sections in
        fragment_dialog_home_popup.xml, and click dispatch happens
        directly on each row's view id (popup_history / popup_settings
        / popup_quit), so the arrays and the icon-id dispatch dance
        aren't needed any more.
    -->


