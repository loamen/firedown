<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Phone landscape: cap the bottom sheet at a comfortable thumb-reach
         width so it sits centred above the home gesture area instead of
         stretching across the whole screen. Tablets (sw600dp) override
         this with a wider value. -->
    <dimen name="bottom_sheet_max_width">480dp</dimen>
    <!-- Landscape height is already small enough that capping further
         leaves a tiny sheet; portrait sets a real cap, here we opt out. -->
    <dimen name="bottom_sheet_max_height">0dp</dimen>
</resources>
