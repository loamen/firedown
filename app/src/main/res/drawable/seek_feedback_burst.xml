<?xml version="1.0" encoding="utf-8"?>
<!--
  Semi-transparent oval used as the "double-tap to seek" feedback
  burst behind the ±10 s label. Positioned in fragment_media_viewer.xml
  so its centre sits off-screen — only the half facing the user is
  visible inside the viewport, mirroring YouTube's half-disc burst.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <solid android:color="#33FFFFFF" />
</shape>
