<?xml version="1.0" encoding="utf-8"?>
<!--
    Rounded chip background for status pills in popup rows (e.g. the
    Desktop site On/Off indicator). Surface tone matches the popup
    icon chip palette so the pill reads as a sibling of the leading
    chip, just smaller and label-shaped instead of icon-shaped.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="?attr/colorSurfaceContainerHighest" />
    <corners android:radius="999dp" />
</shape>
