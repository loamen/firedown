<?xml version="1.0" encoding="utf-8"?>
<!--
    Rounded-square frame behind the popup identity favicon.
    Matches the DuckDuckGo-style site-header treatment: a 40dp
    surface-variant tile padded down to a 24dp favicon, so any
    favicon (square, transparent, monochrome) reads as a single
    coherent identity chip rather than floating on the sheet.

    Uses ?attr/colorSurfaceVariant directly so the drawable resolves
    correctly regardless of inflation context — a custom theme attr
    didn't resolve in some inflater contexts and the frame
    disappeared. The incognito sheet theme overrides
    colorSurfaceVariant to a purple-family tone so the tile reads
    against the purple sheet bg instead of clashing as gray.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="?attr/colorSurfaceVariant" />
    <corners android:radius="10dp" />
</shape>
