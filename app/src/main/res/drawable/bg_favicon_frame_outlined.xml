<?xml version="1.0" encoding="utf-8"?>
<!--
    Outlined frame behind list-row favicons (history / bookmarks).
    1dp colorOutlineVariant stroke, transparent fill, 10dp corners.
    Matches the bg_popup_favicon sizing (40dp tile, 28dp favicon
    inside) but stays out of the way of branded favicons that
    already carry their own background — the tonal version of this
    frame double-decorated brand pills (Kick on green inside a gray
    box, etc). The outline reads as a column slot rather than a
    chip in its own right.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <stroke
        android:width="1dp"
        android:color="?attr/colorOutlineVariant" />
    <corners android:radius="10dp" />
</shape>
