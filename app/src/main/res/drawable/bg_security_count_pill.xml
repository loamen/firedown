<?xml version="1.0" encoding="utf-8"?>
<!--
    Tappable count pill on the security sheet's protection rows — holds the
    per-page block count + a chevron, and is the drill-in target (distinct
    from the row's protection toggle). surfaceContainerHighest reads as one
    tone above the sheet surface so it looks like a button without a loud
    container; selectableItemBackground ripple is layered on top in the
    layout. Incognito retint is applied in the fragment if needed.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="?attr/colorSurfaceContainerHighest" />
    <corners android:radius="20dp" />
</shape>
