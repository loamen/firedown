<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/home">
    <fragment
        android:id="@+id/home"
        android:name="com.solarized.firedown.phone.fragments.HomeFragment">
        <action
            android:id="@+id/action_home_to_home_incognito"
            app:destination="@id/home_incognito"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_home_to_bookmarks"
            app:destination="@id/nav_graph_bookmark" />
        <action
            android:id="@+id/action_home_to_history"
            app:destination="@id/nav_graph_history" />
    </fragment>

    <fragment
        android:id="@+id/home_incognito"
        android:name="com.solarized.firedown.phone.fragments.HomeIncognitoFragment">
        <action
            android:id="@+id/action_home_incognito_to_home"
            app:destination="@id/home"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_home_incognito_to_bookmarks"
            app:destination="@id/nav_graph_bookmark" />
        <action
            android:id="@+id/action_home_incognito_to_history"
            app:destination="@id/nav_graph_history" />
    </fragment>
    <fragment
        android:id="@+id/browser"
        android:name="com.solarized.firedown.phone.fragments.BrowserFragment">
        <action
            android:id="@+id/action_browser_to_bookmarks"
            app:destination="@id/nav_graph_bookmark" />
        <action
            android:id="@+id/action_browser_to_history"
            app:destination="@id/nav_graph_history" />
        <!--
            Direct entry to the bookmark editor, used by the
            'Edit bookmark' popup item on the browser. Old flow opened
            BookmarkActivity with BOOKMARK_EDIT + ITEM_ID extras; new
            flow passes ITEM_ID as a nav argument and lands directly
            on the edit destination.
        -->
        <action
            android:id="@+id/action_browser_to_bookmark_edit"
            app:destination="@id/web_bookmark_edit" />
    </fragment>
    <fragment
        android:id="@+id/tabs"
        android:name="com.solarized.firedown.phone.fragments.TabsHolderFragment">

        <argument
            android:name="com.solarized.firedown.OPEN_INCOGNTO"
            app:argType="boolean"
            android:defaultValue="false" />

        <!-- Back to regular home, clearing entire back stack -->
        <action
            android:id="@+id/action_tabs_to_home"
            app:destination="@id/home"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />

        <!-- Back to incognito home, clearing entire back stack -->
        <action
            android:id="@+id/action_tabs_to_home_incognito"
            app:destination="@id/home_incognito"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />

        <!-- Back to browser, just pop tabs -->
        <action
            android:id="@+id/action_tabs_to_browser"
            app:destination="@id/browser"
            app:popUpTo="@id/tabs"
            app:popUpToInclusive="true" />

    </fragment>
    <fragment
        android:id="@+id/tabs_archive"
        android:name="com.solarized.firedown.phone.fragments.TabsArchiveFragment" >
        <action
            android:id="@+id/action_archive_to_browser"
            app:destination="@id/browser"
            app:popUpTo="@id/home"
            app:popUpToInclusive="false" />
    </fragment>
    <dialog
        android:id="@+id/dialog_new_tabs"
        android:name="com.solarized.firedown.phone.dialogs.NewTabSheetDialogFragment" />
    <dialog
        android:id="@+id/dialog_delete_tabs"
        android:name="com.solarized.firedown.phone.dialogs.DeleteTabsDialogFragment" />
    <dialog
        android:id="@+id/dialog_home_popup"
        android:name="com.solarized.firedown.phone.dialogs.PopupHomeSheetDialogFragment" />
    <dialog
        android:id="@+id/dialog_browser_popup"
        android:name="com.solarized.firedown.phone.dialogs.PopupBrowserSheetDialogFragment" />
    <dialog
        android:id="@+id/dialog_notifications_manager"
        android:name="com.solarized.firedown.ui.NotificationsManagerDialog" />
    <dialog
        android:id="@+id/dialog_rename"
        android:name="com.solarized.firedown.phone.dialogs.RenameFileDialog" />
    <dialog
        android:id="@+id/dialog_file_info"
        android:name="com.solarized.firedown.phone.dialogs.InfoBottomSheetDialogFragment" />
    <dialog
        android:id="@+id/dialog_security_info"
        android:name="com.solarized.firedown.phone.dialogs.SecurityStateSheetDialogFragment" >
        <action
            android:id="@+id/action_security_to_cert"
            app:popUpTo="@+id/dialog_security_info"
            app:popUpToInclusive="true"
            app:destination="@id/dialog_security_cert" />
        <action
            android:id="@+id/action_security_to_clear"
            app:popUpTo="@+id/dialog_security_info"
            app:popUpToInclusive="true"
            app:destination="@id/dialog_security_clear" />
        <!-- Drill-down to per-host detail sheet. Pops the security sheet
             on the way through, mirroring how action_security_to_cert
             and action_security_to_clear already work — the user is
             drilling into one specific concern, the parent sheet is
             redundant once we're in the detail. Back-press from the
             detail sheet returns to the browser, not the security
             sheet (consistent with the rest of the security drill-downs). -->
        <action
            android:id="@+id/action_security_to_blocked_trackers_detail"
            app:popUpTo="@+id/dialog_security_info"
            app:popUpToInclusive="true"
            app:destination="@id/dialog_blocked_trackers_detail" />
    </dialog>
    <dialog
        android:id="@+id/dialog_blocked_trackers_detail"
        android:name="com.solarized.firedown.phone.dialogs.BlockedTrackersDetailDialogFragment" />
    <dialog
        android:id="@+id/dialog_search_engine"
        android:name="com.solarized.firedown.phone.dialogs.SearchEngineSheetDialogFragment" />
    <dialog
        android:id="@+id/dialog_sort"
        android:name="com.solarized.firedown.phone.dialogs.DownloadsSortDialogFragment" />
    <dialog
        android:id="@+id/dialog_security_clear"
        android:name="com.solarized.firedown.phone.dialogs.ClearBrowsingDialogFragment" />
    <dialog
        android:id="@+id/dialog_security_cert"
        android:name="com.solarized.firedown.phone.dialogs.CertDialogFragment" />
    <dialog
        android:id="@+id/dialog_browser_content"
        android:name="com.solarized.firedown.phone.dialogs.BrowserContentDialogFragment" />
    <dialog
        android:id="@+id/dialog_browser_download"
        android:name="com.solarized.firedown.phone.dialogs.BrowserDownloadDialogFragment" />
    <dialog
        android:id="@+id/dialog_browser_open_in_app"
        android:name="com.solarized.firedown.phone.dialogs.BrowserAppDialogFragment" />
    <dialog
        android:id="@+id/dialog_browser_options"
        android:name="com.solarized.firedown.phone.dialogs.BrowserOptionHolderSheetDialogFragment" />
    <dialog
        android:id="@+id/dialog_delete_files"
        android:name="com.solarized.firedown.phone.dialogs.DeleteDownloadsDialogFragment" />
    <dialog
        android:id="@+id/dialog_save_file"
        android:name="com.solarized.firedown.phone.dialogs.SaveFileDialog" />
    <dialog
        android:id="@+id/dialog_delete_clipboard"
        android:name="com.solarized.firedown.phone.dialogs.ClipboardDialogFragment" />

    <!--
        Bookmark + History destinations live inside their own child
        graphs (kept separate to scope their inner dialogs). Nested
        into root via include so home / home_incognito / browser can
        reach them via nav actions. Replaces the previous
        BookmarkActivity / HistoryActivity wrappers that hosted these
        graphs in their own NavHostFragment.
    -->
    <include app:graph="@navigation/nav_graph_bookmark" />
    <include app:graph="@navigation/nav_graph_history" />

</navigation>