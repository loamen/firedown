<?xml version="1.0" encoding="utf-8"?>
<!--
  Captured-content list row. Mirrors fragment_download_item.xml's
  structure for cross-screen consistency: thumbnail on the left,
  vertical text column in the middle (filename / mime · domain /
  tags), action button on the right edge.

  Card background uses surfaceContainerLow with zero elevation —
  enough tonal contrast against the bottom-sheet surface for the
  rows to read as discrete items (the sheet's appbar doesn't lift,
  so we need *some* per-row containment) without the heavy
  elevated-card shadow.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/item_holder"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/item_download_more_checked"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:layout_marginStart="@dimen/list_spacing"
        android:visibility="gone"
        app:srcCompat="@drawable/ic_baseline_check_circle_24"
        app:tint="?attr/colorPrimaryContainer" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/item"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/list_spacing"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="@dimen/list_spacing"
        android:layout_marginBottom="4dp"
        android:layout_weight="1"
        app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/transparent"
        app:strokeWidth="2dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/list_download_image_height"
            android:layout_margin="@dimen/list_margin">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/image"
                android:layout_width="@dimen/list_download_image_width"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:adjustViewBounds="true"
                android:background="@drawable/mask_image_rounded"
                android:contentDescription="@null"
                android:duplicateParentState="true"
                android:outlineProvider="background"
                android:scaleType="centerCrop"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Text column: filename / mime · domain / tags. Vertical
                 LinearLayout with center-vertical gravity so the
                 three lines distribute evenly inside the 64dp row
                 regardless of which tag combo is visible. -->
            <LinearLayout
                android:id="@+id/text_column"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:paddingStart="@dimen/list_margin"
                android:paddingEnd="0dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/item_download_more"
                app:layout_constraintStart_toEndOf="@id/image"
                app:layout_constraintTop_toTopOf="parent">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/file_name"
                    style="@style/TextAppearance.Material3.TitleSmall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="marquee"
                    android:singleLine="true"
                    android:textColor="?attr/colorOnSurface"
                    tools:text="video_file.mp4" />

                <!-- Meta line: mime label · globe · domain. -->
                <LinearLayout
                    android:id="@+id/row_meta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/mime_text"
                        style="@style/MimePrimaryLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="VÍDEO · " />

                    <ImageView
                        android:id="@+id/file_url_icon"
                        android:layout_width="@dimen/list_item_domain"
                        android:layout_height="@dimen/list_item_domain"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_baseline_language_24"
                        app:tint="?attr/colorOnSurfaceVariant" />

                    <TextView
                        android:id="@+id/file_url"
                        style="@style/TextAppearance.Material3.LabelSmall"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:singleLine="true"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        tools:text="m.youtube.com" />

                </LinearLayout>

                <!-- Tag row: quality · duration. Single horizontal
                     line; either or both can be GONE at bind time. -->
                <LinearLayout
                    android:id="@+id/tag_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tag_quality"
                        style="@style/TextAppearance.Material3.BodySmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:singleLine="true"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:visibility="gone"
                        tools:text="1080p"
                        tools:visibility="visible" />

                    <TextView
                        android:id="@+id/tag_separator"
                        style="@style/TextAppearance.Material3.BodySmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:text="@string/separator"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:visibility="gone"
                        tools:visibility="visible" />

                    <TextView
                        android:id="@+id/tag_duration"
                        style="@style/TextAppearance.Material3.BodySmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:singleLine="true"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:visibility="gone"
                        tools:text="03:45"
                        tools:visibility="visible" />

                </LinearLayout>

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/item_download_more"
                style="@style/Theme.FireDown.More.Button"
                app:icon="@drawable/ic_baseline_more_vert_24"
                app:iconTint="?attr/colorOnSurfaceVariant"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
