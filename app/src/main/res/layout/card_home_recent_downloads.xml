<?xml version="1.0" encoding="utf-8"?>
<!--
  Minimalist Downloads entry card on the home page. Same shape as
  the Safe Folder card — icon + title + 'N files saved · X.Y GB'
  subtitle — so the home reads as a small set of equal-weight
  destinations rather than competing surfaces. Tap routes to
  DownloadsActivity; long-pressing the bottom-bar Downloads button
  is the path to a quick-list preview (DownloadsQuickAccessSheet).
-->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/recent_downloads_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clickable="true"
    android:focusable="true"
    android:visibility="gone"
    app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp">

        <FrameLayout
            android:id="@+id/recent_downloads_chip"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_icon_container_primary">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/recent_downloads_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/download_24"
                app:tint="?attr/colorOnPrimaryContainer" />

        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/recent_downloads_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/navigation_downloads"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                android:textColor="?attr/colorOnSurface" />

            <!--
                'N files saved · X.Y GB' subtitle. Plural quantity drives
                the file label; size suffix is appended in HomeFragment
                from Utils.readableFileSize (kB / MB / GB). Hidden when
                count = 0 (matches Safe Folder behaviour).
            -->
            <TextView
                android:id="@+id/recent_downloads_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:visibility="gone"
                tools:text="150 files saved · 2.4 GB"
                tools:visibility="visible" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
