<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <include layout="@layout/dialog_drag_handle" />


    <!-- Title row. Mirrors the host_secure / host_clear rows on the
         parent security sheet for visual continuity. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="56dp"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <androidx.appcompat.widget.AppCompatImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="16dp"
            app:srcCompat="@drawable/footprint_24"
            app:tint="?attr/colorOnSurfaceVariant" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                style="@style/TextAppearance.Material3.TitleMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/blocked_trackers_detail_title"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/detail_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="2"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp"
                tools:text="12 trackers blocked on this page" />

        </LinearLayout>

    </LinearLayout>


    <!-- Empty state — the parent sheet only routes here when total > 0
         so this is rare (a race where everything got cleared between
         the parent navigate and this onCreateView). -->
    <TextView
        android:id="@+id/detail_empty"
        style="@style/TextAppearance.Material3.BodyMedium"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="32dp"
        android:text="@string/blocked_trackers_detail_empty"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:visibility="gone" />


    <!-- Categories + per-category domains. Bound at runtime to a flat
         list of mixed view-types (header / domain row) — RecyclerView
         is overkill for a typical 5-50 entry list, but the same
         RoundedCorners-style cards used elsewhere in the app expect
         it, and it gives us free recycling on long pages. -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/detail_recycler"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        android:scrollbars="vertical" />


</LinearLayout>
