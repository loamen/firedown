<?xml version="1.0" encoding="utf-8"?>
<!--
  "Continue browsing" card on the regular home page. A one-tap
  shortcut back into the user's most recent open, non-home tab —
  shown when the user has landed on home but still has a real tab
  open behind it. Wired in HomeFragment by observing the tab list
  (GeckoStateViewModel.getTabs) and refreshed on resume. Tap →
  switches to that tab via the same openSessionId flow the media
  strip uses.

  Regular mode only: HomeIncognitoFragment never inflates it, and
  the bind logic skips any incognito session, so no private tab
  can surface here.

  Outlined (transparent fill + 1dp outlineVariant stroke) rather than
  a filled tint — this is a navigation affordance, not a content
  shelf, so the outline reads as a deliberate "header" above the
  filled Downloads / Vault / Trackers cards instead of a content card
  that failed to take the user's palette. Stays neutral in every
  palette; the favicon (a real site icon) is the visual anchor. Shape
  and metrics mirror view_home_media_strip so the cards read as
  siblings.
-->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/home_return_tab"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clickable="true"
    android:focusable="true"
    android:visibility="gone"
    app:cardBackgroundColor="@android:color/transparent"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="?attr/colorOutlineVariant"
    app:strokeWidth="1dp"
    tools:visibility="visible">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="84dp"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp">

        <!--
            Favicon of the tab we'll return to. 24dp icon centred in a
            40dp slot so its centre and the text column align with the
            other home cards' chips. No chip background — the favicon
            sits directly on the card surface, same as the media strip.
        -->
        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/home_return_tab_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:scaleType="fitCenter" />

        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/home_return_tab_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.08"
                android:text="@string/home_return_tab"
                android:textAllCaps="true"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="CONTINUE BROWSING" />

            <TextView
                android:id="@+id/home_return_tab_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                android:textColor="?attr/colorOnSurface"
                tools:text="Hacker News" />

            <TextView
                android:id="@+id/home_return_tab_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:visibility="gone"
                tools:text="news.ycombinator.com"
                tools:visibility="visible" />

        </LinearLayout>

        <!--
            Trailing chevron — a static affordance signalling the whole
            card navigates forward into the tab (no in-place action like
            the media strip's play/pause). Decorative; the card itself
            carries the click + content description.
        -->
        <androidx.appcompat.widget.AppCompatImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="8dp"
            android:contentDescription="@null"
            android:scaleType="centerInside"
            android:src="@drawable/ic_chevron_right_24"
            app:tint="?attr/colorOnSurfaceVariant" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
