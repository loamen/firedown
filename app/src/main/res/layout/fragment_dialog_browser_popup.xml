<?xml version="1.0" encoding="utf-8"?>
<!--
    Browser "more" popup sheet.

    Card removed, rows sit flat on the sheet surface, semantic groups
    separated by hairline rules. Tried section labels (PAGE / LIBRARY
    / APP) over the same rules, but the labels were redundant — the
    rules already broke the groups apart and the rows speak for
    themselves. SecuritySheet keeps labelled sections because its
    rows (toggles vs drill-downs) carry less self-evident structure.

    Shape (top→bottom):
      1. Drag handle (shared include).                    [pinned]
      2. Site-identity row: favicon + page title +        [pinned]
         hostname. Same identity vocabulary the
         SecuritySheet uses, scoped to "act on this
         page". Stays pinned — it's the anchor, scrolling
         the title away would lose the context the rest
         of the rows act on. Dismiss is swipe-down or
         scrim-tap; no inline X — the drag handle and the
         taller header read clearly enough as a sheet,
         and dropping the X also drops a second dismiss
         affordance that did the same job.
      3. Identity / quick-row divider.                    [pinned]
      4. ─── scroll boundary ───
      5. Quick-row header: Back · Forward · Share · Refresh.
      6. Quick-row / menu divider.
      7. Page actions    — Bookmark page, Find in page, Desktop site
      8. Library         — Bookmarks, History, Safe Folder
      9. App + exit      — Settings, optional Quit

    Row anatomy:
      • 48dp tall, 16dp horizontal padding — denser than the
        56dp the sheet used to render at, fits more rows on
        short screens without the list feeling crowded since
        each row is still icon + single line
      • TextView with drawableStartCompat icon at 16dp drawablePadding,
        TitleMedium / 15sp text, onSurfaceVariant
      • Desktop site carries a MaterialSwitch as duplicate-parent-state
        status (whole row is the click target)
      • Everything else has no trailing element — the ripple is enough

    State handling stays in the fragment:
      • Bookmark page row flips its drawableStart icon and label
        between outline/"Bookmark page" and filled/"Edit bookmark"
        based on mHasBookmark; dispatched id swaps in lockstep.
      • Vault row swaps to Downloads in incognito (icon + label +
        dispatched id).
      • Desktop site switch mirrors the current tab's isDesktop().
      • Quit row stays GONE unless SETTINGS_QUIT_PREF is on; the row
        uses colorPrimary text + tint so the destructive treatment
        matches Downloads' / Bookmarks' Delete row.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <include
        layout="@layout/dialog_drag_handle" />


    <!-- Site identity. Mirrors the SecuritySheet's identity block
         (favicon + title + host) so the two sheets read as siblings
         on the browser surface. Renders taller than the menu rows
         (minHeight 72dp via 12dp vertical padding) so it reads as a
         header, not just another list row. -->
    <LinearLayout
        android:id="@+id/popup_identity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="72dp"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingVertical="12dp">

        <!-- 40dp tinted surface tile with the 24dp favicon centred
             inside (8dp padding → 24dp content). DuckDuckGo-style
             frame so transparent / monochrome / oddly-cropped
             favicons still read as a single identity chip rather
             than floating on the sheet. -->
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/popup_identity_favicon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_popup_favicon"
            android:contentDescription="@null"
            android:padding="8dp"
            android:scaleType="centerInside"
            tools:src="@drawable/ic_firedown" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/popup_identity_title"
                style="@style/TextAppearance.Material3.TitleSmall.Emphasized"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="EL PAÍS: el periódico global" />

            <TextView
                android:id="@+id/popup_identity_host"
                style="@style/TextAppearance.Material3.BodyMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="elpais.com" />

        </LinearLayout>

    </LinearLayout>


    <!-- Pinned divider seals the identity row off from the scrolling
         content below; the title stays in view as the rest of the
         sheet scrolls past. Matches the visual break the SecuritySheet
         renders between its identity block and its first section. -->
    <View
        style="@style/Firedown.Divider.InCard"
        android:layout_marginTop="8dp" />


    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="8dp">


            <include
                layout="@layout/fragment_dialog_browser_popup_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />


            <View
                style="@style/Firedown.Divider.InCard"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp" />


            <!-- New tab — always opens a REGULAR tab (dispatches
                 R.id.new_tab, which BrowserFragment forces to
                 non-incognito), so from incognito chrome this is the
                 explicit exit-to-normal-tab action. Mirrors the
                 fixed-meaning rows browsers like Chrome/Firefox show. -->
            <LinearLayout
                android:id="@+id/popup_new_tab"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <TextView
                    style="@style/TextAppearance.Material3.TitleMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:drawablePadding="16dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/popup_tabs_new"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="15sp"
                    app:drawableStartCompat="@drawable/ic_web_24"
                    app:drawableTint="?attr/colorOnSurfaceVariant" />

            </LinearLayout>


            <!-- New private tab — always opens an INCOGNITO tab
                 (dispatches R.id.new_incognito_tab). Fixed meaning in
                 both modes, matching the New tab row above. -->
            <LinearLayout
                android:id="@+id/popup_new_incognito_tab"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <TextView
                    style="@style/TextAppearance.Material3.TitleMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:drawablePadding="16dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/open_new_private_tab_2"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="15sp"
                    app:drawableStartCompat="@drawable/ic_incognito_24"
                    app:drawableTint="?attr/colorOnSurfaceVariant" />

            </LinearLayout>


            <!-- Bookmark page — drawableStart + label flip in
                 applyBookmarkState; dispatched id flips in bindRows. -->
            <LinearLayout
                android:id="@+id/popup_bookmark_page"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <TextView
                    android:id="@+id/popup_bookmark_page_text"
                    style="@style/TextAppearance.Material3.TitleMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:drawablePadding="16dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/browser_menu_bookmark_this_page_2"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="15sp"
                    app:drawableStartCompat="@drawable/ic_bookmark_border_24"
                    app:drawableTint="?attr/colorOnSurfaceVariant" />

            </LinearLayout>


            <!-- Find in page — pure action, no trailing element. -->
            <LinearLayout
                android:id="@+id/popup_find"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <TextView
                    style="@style/TextAppearance.Material3.TitleMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:drawablePadding="16dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/browser_menu_find_in_page"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="15sp"
                    app:drawableStartCompat="@drawable/ic_search_24"
                    app:drawableTint="?attr/colorOnSurfaceVariant" />

            </LinearLayout>


            <!-- Desktop site — MaterialSwitch reflects isDesktop().
                 Whole row is the click target; switch is duplicate-
                 parent-state status, not the hit target. -->
            <LinearLayout
                android:id="@+id/popup_desktop"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <TextView
                    style="@style/TextAppearance.Material3.TitleMedium"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:drawablePadding="16dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/browser_menu_desktop_site"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="15sp"
                    app:drawableStartCompat="@drawable/ic_computer_24"
                    app:drawableTint="?attr/colorOnSurfaceVariant" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/popup_desktop_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:clickable="false"
                    android:duplicateParentState="true"
                    android:focusable="false" />

            </LinearLayout>


            <View
                style="@style/Firedown.Divider.InCard"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp" />


            <!-- Bookmarks. -->
            <LinearLayout
                android:id="@+id/popup_bookmarks"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <TextView
                    style="@style/TextAppearance.Material3.TitleMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:drawablePadding="16dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/library_bookmarks"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="15sp"
                    app:drawableStartCompat="@drawable/ic_bookmarks_24"
                    app:drawableTint="?attr/colorOnSurfaceVariant" />

            </LinearLayout>


            <!-- History. -->
            <LinearLayout
                android:id="@+id/popup_history"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <TextView
                    style="@style/TextAppearance.Material3.TitleMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:drawablePadding="16dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/library_history"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="15sp"
                    app:drawableStartCompat="@drawable/ic_history_24"
                    app:drawableTint="?attr/colorOnSurfaceVariant" />

            </LinearLayout>


            <!-- Vault (Downloads in incognito; the fragment
                 repaints drawableStart + label + dispatched id). -->
            <LinearLayout
                android:id="@+id/popup_vault"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <TextView
                    android:id="@+id/popup_vault_text"
                    style="@style/TextAppearance.Material3.TitleMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:drawablePadding="16dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/navigation_vault"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="15sp"
                    app:drawableStartCompat="@drawable/ic_lock_24"
                    app:drawableTint="?attr/colorOnSurfaceVariant" />

            </LinearLayout>


            <View
                style="@style/Firedown.Divider.InCard"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp" />


            <!-- Settings. -->
            <LinearLayout
                android:id="@+id/popup_settings"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <TextView
                    style="@style/TextAppearance.Material3.TitleMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:drawablePadding="16dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/browser_menu_settings"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="15sp"
                    app:drawableStartCompat="@drawable/ic_settings_24"
                    app:drawableTint="?attr/colorOnSurfaceVariant" />

            </LinearLayout>


            <!-- Destructive Quit — GONE unless SETTINGS_QUIT_PREF
                 is on. colorPrimary text + drawable tint is what
                 differentiates it. -->
            <LinearLayout
                android:id="@+id/popup_quit"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    style="@style/TextAppearance.Material3.TitleMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:drawablePadding="16dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/delete_browsing_data_on_quit_action"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="15sp"
                    app:drawableStartCompat="@drawable/ic_logout_24"
                    app:drawableTint="?attr/colorPrimary" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
