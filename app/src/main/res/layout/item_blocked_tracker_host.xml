<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="6dp"
    android:paddingBottom="6dp">

    <!-- Host + count share the Top-trackers list typography: 13sp
         monospace at textColorPrimary (see item_top_tracker), so the two
         blocked detail sheets and the Home "Top trackers" list read
         identically. Monospace keeps the count column intrinsically
         tabular. -->
    <TextView
        android:id="@+id/host_label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:fontFamily="monospace"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="13sp"
        android:maxLines="1"
        android:ellipsize="middle"
        tools:text="securepubads.g.doubleclick.net" />

    <TextView
        android:id="@+id/host_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:fontFamily="monospace"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="13sp"
        android:maxLines="1"
        tools:text="×3" />

</LinearLayout>
