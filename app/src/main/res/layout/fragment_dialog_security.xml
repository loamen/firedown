<?xml version="1.0" encoding="utf-8"?>
<!--
    Per-site security / protection sheet.

    Sections (top → bottom):
      1. Site identity header (favicon + host + URL) — anchors the
         sheet to a specific site.
      2. PROTECTION section — Block ads toggle, Tracking protection
         toggle (with subtext describing the current state). Moved to
         the top: protection toggles are the primary reason users
         open this sheet, and they double as the legend for the
         "Blocked on this page" rows below.
      3. BLOCKED ON THIS PAGE section — two list rows (Ads, Trackers)
         showing the per-page block count as a trailing number with a
         chevron. Tap drills into the per-mechanism detail sheet:
           - Ads → BlockedAdsDetailDialogFragment (uBlock blocks)
           - Trackers → BlockedTrackersDetailDialogFragment (ETP blocks)
         Previously these were two clickable stat cards sharing a
         style with TrackersInfoSheet's three-card stat row — same
         visual, different interaction (TrackersInfoSheet's cards
         are passive numbers). The list-row format makes the tap
         affordance explicit and removes the SecuritySheet ↔
         TrackersInfoSheet visual collision.
      4. MANAGE section — Connection (drill-down to cert details),
         Clear browsing data (drill-down).

    All row IDs (ads_stat_card, trackers_stat_card, ads_counter,
    trackers_counter, ads_toogle, tracking_toogle, tracking_subtext,
    tracking_icon, host_secure, host_secure_text, host_clear) are
    preserved from the previous layout so the fragment's findViewById
    + click-handler wiring stays untouched.

    Outer LinearLayout is left unpadded because
    BaseBottomSheetDialogFragment's window-insets listener applies
    padding directly to mView (same pattern as the TrackersInfoSheet
    layout).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <include layout="@layout/dialog_drag_handle" />


    <!--
        Site identity. Stays at the top as a distinct block above the
        protection controls — it's the site anchor, not a control, so
        it sits in its own hierarchy level.
    -->
    <LinearLayout
        android:id="@+id/host_domain"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/host_image"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="16dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/host"
                style="@style/TextAppearance.Material3.TitleSmall.Emphasized"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="marquee"
                android:maxLines="1"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="CNN" />

            <TextView
                android:id="@+id/host_url"
                style="@style/TextAppearance.Material3.BodyMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="www.cnn.com" />

        </LinearLayout>

    </LinearLayout>


    <!--
        Body container — wrapped in a NestedScrollView so the sheet's
        full content stays reachable in landscape and on short screens.
        The drag-handle + site-identity rows above stay outside the
        scroller (they're the bottom-sheet drag zone). paddingHorizontal
        mirrors TrackersInfoSheet (24dp).
    -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingBottom="8dp">


        <!-- ── Protection toggles ─────────────────────────────────── -->
        <!-- Block ads + Tracking protection — placed at the top
             because they're the primary reason users open this
             sheet, and they double as the legend for the count
             rows below. -->


        <!--
            Block ads — toggle row. The row's whole surface is the
            click target; the switch carries duplicateParentState so
            tapping anywhere in the row flips it, matching how the
            popup's Desktop site row behaves.
        -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:contentDescription="@null"
                app:srcCompat="@drawable/ads_click_24"
                app:tint="?attr/colorOnSurfaceVariant" />

            <TextView
                style="@style/TextAppearance.Material3.TitleMedium"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/security_block_ads"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="15sp" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/ads_toogle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp" />

        </LinearLayout>


        <!--
            Tracking protection — toggle row with a subtitle line for
            the "if something looks broken, try turning it off" hint.
            Subtitle copy is swapped in updateTrackingUI based on the
            current toggle state.
        -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:minHeight="64dp"
            android:orientation="horizontal"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/tracking_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:contentDescription="@null"
                app:srcCompat="@drawable/ic_shield_24"
                app:tint="?attr/colorOnSurfaceVariant" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    style="@style/TextAppearance.Material3.TitleMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/security_tracking_protection"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tracking_subtext"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="2"
                    android:text="@string/protection_panel_etp_toggle_enabled_description_2"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="12sp" />

            </LinearLayout>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/tracking_toogle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp" />

        </LinearLayout>


        <!-- Group divider — separates the protection toggles above
             from the per-page block counts below. colorOutlineVariant
             at 1dp matches the standard M3 inline divider. -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="4dp"
            android:background="?attr/colorOutlineVariant" />


        <!--
            Ads row. Two-line: title (label) + subtitle ("on this
            page") so the row is self-sufficient now that the
            BLOCKED ON THIS PAGE section header is gone. Same shape
            as the Tracking protection row above. Tap drills into
            BlockedAdsDetailDialogFragment. IDs preserved
            (ads_stat_card, ads_counter) so the fragment's
            findViewById + setOnClickListener wiring stays untouched.
        -->
        <LinearLayout
            android:id="@+id/ads_stat_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:minHeight="64dp"
            android:orientation="horizontal"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:contentDescription="@null"
                app:srcCompat="@drawable/ads_click_24"
                app:tint="?attr/colorOnSurfaceVariant" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    style="@style/TextAppearance.Material3.TitleMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/security_stat_ads_blocked"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/security_stat_scope_on_this_page"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- Tabular-numeric so the count column lines up between
                 the Ads and Trackers rows even as values shift. -->
            <TextView
                android:id="@+id/ads_counter"
                style="@style/TextAppearance.Material3.TitleMedium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:fontFeatureSettings="tnum"
                android:textColor="?attr/colorPrimary"
                android:textSize="15sp"
                tools:text="24" />

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:contentDescription="@null"
                app:srcCompat="@drawable/ic_chevron_right_24"
                app:tint="?attr/colorOnSurfaceVariant" />

        </LinearLayout>


        <!--
            Trackers row. Tap drills into
            BlockedTrackersDetailDialogFragment, gated in the fragment
            on (mTrackingEnabledForSite && mTrackersBlockedTotal > 0).
            ID preserved as trackers_stat_card. Counter preserved as
            trackers_counter.
        -->
        <LinearLayout
            android:id="@+id/trackers_stat_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:minHeight="64dp"
            android:orientation="horizontal"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:contentDescription="@null"
                app:srcCompat="@drawable/ic_shield_24"
                app:tint="?attr/colorOnSurfaceVariant" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    style="@style/TextAppearance.Material3.TitleMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/security_stat_trackers_blocked"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/security_stat_scope_on_this_page"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="12sp" />

            </LinearLayout>

            <TextView
                android:id="@+id/trackers_counter"
                style="@style/TextAppearance.Material3.TitleMedium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:fontFeatureSettings="tnum"
                android:textColor="?attr/colorPrimary"
                android:textSize="15sp"
                tools:text="14" />

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:contentDescription="@null"
                app:srcCompat="@drawable/ic_chevron_right_24"
                app:tint="?attr/colorOnSurfaceVariant" />

        </LinearLayout>


        <!-- Group divider — separates the count rows above from the
             site-management actions below. -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="4dp"
            android:background="?attr/colorOutlineVariant" />


        <!-- Connection — drill-down to cert details. Icon and label
             flip between secure / insecure variants in the fragment. -->
        <LinearLayout
            android:id="@+id/host_secure"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/host_secure_text"
                style="@style/TextAppearance.Material3.TitleMedium"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:drawablePadding="16dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/connection_secure"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="15sp"
                app:drawableStartCompat="@drawable/encryption_light_24"
                app:drawableTint="?attr/colorOnSurfaceVariant" />

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:contentDescription="@null"
                app:srcCompat="@drawable/ic_chevron_right_24"
                app:tint="?attr/colorOnSurfaceVariant" />

        </LinearLayout>


        <!-- Clear cookies / site data for this hostname. -->
        <LinearLayout
            android:id="@+id/host_clear"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                style="@style/TextAppearance.Material3.TitleMedium"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:drawablePadding="16dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/settings_clear_browsing"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="15sp"
                app:drawableStartCompat="@drawable/ic_baseline_delete_24"
                app:drawableTint="?attr/colorOnSurfaceVariant" />

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:contentDescription="@null"
                app:srcCompat="@drawable/ic_chevron_right_24"
                app:tint="?attr/colorOnSurfaceVariant" />

        </LinearLayout>

    </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
