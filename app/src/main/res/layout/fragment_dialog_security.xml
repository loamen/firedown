<?xml version="1.0" encoding="utf-8"?>
<!--
    Per-site security / protection sheet.

    Sections (top → bottom):
      1. Site identity header (favicon + host + URL) — anchors the
         sheet to a specific site.
      2. PROTECTION section — one row per mechanism (Block ads,
         Tracking protection). Each row merges the protection toggle
         with that mechanism's live per-page block count: the count is
         a tappable pill (drills into the detail sheet), the switch
         flips protection. Previously these were split across two
         sections — a PROTECTION toggle row and a separate BLOCKED ON
         THIS PAGE count row — which showed each concept (and its icon)
         twice. Detail sheets:
           - Ads → BlockedAdsDetailDialogFragment (uBlock blocks)
           - Trackers → BlockedTrackersDetailDialogFragment (ETP blocks)
      3. MANAGE section — Connection (drill-down to cert details),
         Clear browsing data (drill-down).

    All IDs (ads_stat_card, trackers_stat_card, ads_counter,
    trackers_counter, ads_toogle, tracking_toogle, tracking_subtext,
    tracking_icon, host_secure, host_secure_text, host_clear) are
    preserved — relocated into the merged rows — so the fragment's
    findViewById + click-handler wiring stays untouched. The count pills
    keep the ads_stat_card / trackers_stat_card ids as the drill target.

    Outer LinearLayout is left unpadded because
    BaseBottomSheetDialogFragment's window-insets listener applies
    padding directly to mView (same pattern as the TrackersInfoSheet
    layout).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <include layout="@layout/dialog_drag_handle" />


    <!--
        Site identity. Stays at the top as a distinct block above the
        protection controls — it's the site anchor, not a control, so
        it sits in its own hierarchy level.
    -->
    <LinearLayout
        android:id="@+id/host_domain"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <!-- 40dp tinted surface tile with the 24dp favicon centred
             inside (8dp padding → 24dp content). Mirrors the browser
             popup's identity chip (bg_popup_favicon) so the two sheets
             read as siblings. -->
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/host_image"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_popup_favicon"
            android:padding="8dp"
            android:scaleType="centerInside" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/host"
                style="@style/TextAppearance.Material3.TitleSmall.Emphasized"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="marquee"
                android:maxLines="1"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="CNN" />

            <TextView
                android:id="@+id/host_url"
                style="@style/TextAppearance.Material3.BodyMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="www.cnn.com" />

        </LinearLayout>

    </LinearLayout>


    <!--
        Body container — wrapped in a NestedScrollView so the sheet's
        full content stays reachable in landscape and on short screens.
        The drag-handle + site-identity rows above stay outside the
        scroller (they're the bottom-sheet drag zone). paddingHorizontal
        mirrors TrackersInfoSheet (24dp).
    -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingBottom="8dp">


        <!-- ── Blocked-on-this-page hero summary ──────────────────────
            Big combined total + two drill-in chips (ads / trackers). The
            chips keep the ads_stat_card / trackers_stat_card ids (drill
            target) and the ads_counter / trackers_counter ids (the number
            inside each), so the fragment's click wiring + count observers
            are unchanged. The hero total (security_total_count) is the sum
            of the two, set by the fragment. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/security_total_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFeatureSettings="tnum"
                android:textColor="?attr/colorPrimary"
                android:textSize="40sp"
                android:textStyle="bold"
                tools:text="38" />

            <TextView
                style="@style/TextAppearance.Material3.BodyMedium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/security_stat_scope_on_this_page"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <!-- Ads chip → BlockedAdsDetailDialogFragment. MaterialCardView
                     carries the id + click (matches TrackersInfoSheet's stat
                     card style); the count is neutral (colorOnSurface), only
                     the hero total stays the primary accent. -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/ads_stat_card"
                    style="@style/TrackersInfoStatCard"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="14dp"
                        android:paddingEnd="8dp"
                        android:paddingVertical="10dp">

                        <TextView
                            android:id="@+id/ads_counter"
                            style="@style/TextAppearance.Material3.TitleMedium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFeatureSettings="tnum"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="15sp"
                            tools:text="24" />

                        <TextView
                            style="@style/TextAppearance.Material3.BodyMedium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="@string/security_stat_ads_blocked"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                        <androidx.appcompat.widget.AppCompatImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginStart="2dp"
                            android:contentDescription="@null"
                            app:srcCompat="@drawable/ic_chevron_right_24"
                            app:tint="?attr/colorOnSurfaceVariant" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Trackers chip → BlockedTrackersDetailDialogFragment -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/trackers_stat_card"
                    style="@style/TrackersInfoStatCard"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="14dp"
                        android:paddingEnd="8dp"
                        android:paddingVertical="10dp">

                        <TextView
                            android:id="@+id/trackers_counter"
                            style="@style/TextAppearance.Material3.TitleMedium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFeatureSettings="tnum"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="15sp"
                            tools:text="14" />

                        <TextView
                            style="@style/TextAppearance.Material3.BodyMedium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="@string/security_stat_trackers_blocked"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                        <androidx.appcompat.widget.AppCompatImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginStart="2dp"
                            android:contentDescription="@null"
                            app:srcCompat="@drawable/ic_chevron_right_24"
                            app:tint="?attr/colorOnSurfaceVariant" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>


        <!-- Group divider — hero summary above, protection toggles below. -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp"
            android:background="?attr/colorOutlineVariant" />


        <!-- ── Protection toggles ─────────────────────────────────── -->


        <!-- Block ads -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:contentDescription="@null"
                app:srcCompat="@drawable/ads_click_24"
                app:tint="?attr/colorOnSurfaceVariant" />

            <TextView
                style="@style/TextAppearance.Material3.TitleMedium"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/security_block_ads"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="15sp" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/ads_toogle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp" />

        </LinearLayout>


        <!-- Tracking protection (with state-dependent subtext) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:minHeight="64dp"
            android:orientation="horizontal"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/tracking_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:contentDescription="@null"
                app:srcCompat="@drawable/ic_shield_24"
                app:tint="?attr/colorOnSurfaceVariant" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    style="@style/TextAppearance.Material3.TitleMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/security_tracking_protection"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tracking_subtext"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="2"
                    android:text="@string/protection_panel_etp_toggle_enabled_description_2"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="12sp" />

            </LinearLayout>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/tracking_toogle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp" />

        </LinearLayout>


        <!-- Group divider — separates protection from the site-management
             actions below. -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="4dp"
            android:background="?attr/colorOutlineVariant" />


        <!-- Connection — drill-down to cert details. Icon and label
             flip between secure / insecure variants in the fragment. -->
        <LinearLayout
            android:id="@+id/host_secure"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/host_secure_text"
                style="@style/TextAppearance.Material3.TitleMedium"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:drawablePadding="16dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/connection_secure"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="15sp"
                app:drawableStartCompat="@drawable/encryption_light_24"
                app:drawableTint="?attr/colorOnSurfaceVariant" />

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:contentDescription="@null"
                app:srcCompat="@drawable/ic_chevron_right_24"
                app:tint="?attr/colorOnSurfaceVariant" />

        </LinearLayout>


        <!-- Clear cookies / site data for this hostname. -->
        <LinearLayout
            android:id="@+id/host_clear"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                style="@style/TextAppearance.Material3.TitleMedium"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:drawablePadding="16dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/settings_clear_browsing"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="15sp"
                app:drawableStartCompat="@drawable/ic_baseline_delete_24"
                app:drawableTint="?attr/colorOnSurfaceVariant" />

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:contentDescription="@null"
                app:srcCompat="@drawable/ic_chevron_right_24"
                app:tint="?attr/colorOnSurfaceVariant" />

        </LinearLayout>

    </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
