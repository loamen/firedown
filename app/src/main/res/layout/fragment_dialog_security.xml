<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <View
        android:id="@+id/divider"
        android:layout_width="60dp"
        android:layout_height="4dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="6dp"
        android:background="@drawable/dialog_rounded_divider" />


    <!-- Site header. Stays as a separate block above the controls card —
         it's site identity, not a control, so distinct hierarchy. -->
    <LinearLayout
        android:id="@+id/host_domain"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/host_image"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="16dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/host"
                style="@style/TextAppearance.Material3.TitleSmall.Emphasized"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="marquee"
                android:maxLines="1"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="CNN" />

            <TextView
                android:id="@+id/host_url"
                style="@style/TextAppearance.Material3.BodyMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="www.cnn.com" />

        </LinearLayout>

    </LinearLayout>


    <!-- One filled card holds every per-site control. Sections are
         separated by colorOutlineVariant rules instead of stacking
         multiple elevated surfaces, matching Material3 list-in-card
         guidance. -->
    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.Material3.CardView.Filled"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">


            <!-- Connection status. Tap to open the cert details. -->
            <LinearLayout
                android:id="@+id/host_secure"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <TextView
                    android:id="@+id/host_secure_text"
                    style="@style/TextAppearance.Material3.TitleMedium"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:drawablePadding="16dp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="@string/connection_secure"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="15sp"
                    app:drawableStartCompat="@drawable/encryption_light_24" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    app:srcCompat="@drawable/ic_chevron_right_24"
                    app:tint="?attr/colorOnSurfaceVariant" />

            </LinearLayout>

            <View
                style="@style/Firedown.Divider.InCard" />


            <!-- Ads / uBlock counter + per-site toggle. -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:minHeight="64dp"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ads_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    app:srcCompat="@drawable/ads_click_24" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/TextAppearance.Material3.TitleMedium"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/security_ads"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="15sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/ads_subtext"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/security_blocked_in_this_page"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/ads_counter"
                            style="@style/TextAppearance.Material3.TitleSmall.Emphasized"
                            android:layout_width="24dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/rounded_primary"
                            android:maxLines="1"
                            android:paddingTop="2dp"
                            android:paddingBottom="2dp"
                            android:textColor="?attr/colorOnPrimaryContainer"
                            android:textSize="11sp" />

                    </LinearLayout>

                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/ads_toogle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp" />

            </LinearLayout>

            <View
                style="@style/Firedown.Divider.InCard" />


            <!-- Tracking-protection section. Toggle row at top, then an
                 expandable per-page breakdown that lights up only when
                 ETP is on AND something has actually been blocked. -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:minHeight="64dp"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/tracking_icon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="16dp"
                        app:srcCompat="@drawable/ic_shield_24" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tracking_text"
                            style="@style/TextAppearance.Material3.TitleMedium"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/quick_settings_sheet_tracking_site_title"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/tracking_subtext"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:maxLines="2"
                            android:text="@string/protection_panel_etp_toggle_enabled_description_2"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/tracking_toogle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp" />

                </LinearLayout>

                <!-- Visually distinct expandable region. Sits on
                     colorSurfaceContainerHighest so the breakdown reads
                     as a sub-area of the tracking row above, not just
                     more list items. Hidden until counts > 0. -->
                <LinearLayout
                    android:id="@+id/blocked_trackers_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/colorSurfaceContainerHighest"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <View
                        android:id="@+id/blocked_trackers_separator"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutlineVariant" />

                    <LinearLayout
                        android:id="@+id/blocked_trackers_summary_row"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <TextView
                            android:id="@+id/blocked_trackers_summary_text"
                            style="@style/TextAppearance.Material3.LabelLarge"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:textColor="?attr/colorOnSurface" />

                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/blocked_trackers_chevron"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            app:srcCompat="@drawable/expand_more_24"
                            app:tint="?attr/colorOnSurfaceVariant" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/blocked_trackers_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingBottom="8dp"
                        android:visibility="gone">

                        <include
                            android:id="@+id/row_cross_site_cookies"
                            layout="@layout/item_blocked_tracker_row" />

                        <include
                            android:id="@+id/row_social_media"
                            layout="@layout/item_blocked_tracker_row" />

                        <include
                            android:id="@+id/row_fingerprinters"
                            layout="@layout/item_blocked_tracker_row" />

                        <include
                            android:id="@+id/row_cryptominers"
                            layout="@layout/item_blocked_tracker_row" />

                        <include
                            android:id="@+id/row_tracking_content"
                            layout="@layout/item_blocked_tracker_row" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <View
                style="@style/Firedown.Divider.InCard" />


            <!-- Clear cookies / site data for this hostname. -->
            <LinearLayout
                android:id="@+id/host_clear"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <TextView
                    style="@style/TextAppearance.Material3.TitleMedium"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:drawablePadding="16dp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="@string/settings_clear_browsing"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="15sp"
                    app:drawableStartCompat="@drawable/ic_baseline_delete_24" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    app:srcCompat="@drawable/ic_chevron_right_24"
                    app:tint="?attr/colorOnSurfaceVariant" />

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>


</LinearLayout>
