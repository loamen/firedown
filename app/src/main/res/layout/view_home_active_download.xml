<?xml version="1.0" encoding="utf-8"?>
<!--
  Active-download strip on the home page. Shows the single newest
  in-flight regular download — if more are queued, a '+N more' suffix
  on the header surfaces the count without expanding the card.

  Three-column layout mirrors the playing-media strip below: pulsing
  Firedown flame (40dp slot) | text column (label + filename +
  LinearProgressIndicator) | percent (44dp trailing slot). The percent
  sits in the same horizontal position as the media card's play/pause
  toggle so the two 'live state' cards line up vertically when stacked.

  Tinted with colorPrimaryContainer to read as 'live' — distinct from
  the surface-container colour the static Downloads / Safe Folder cards
  use. Whole card is tappable; tap → DownloadsActivity.
-->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/active_download_strip"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clickable="true"
    android:focusable="true"
    android:visibility="gone"
    app:cardBackgroundColor="?attr/colorPrimaryContainer"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp">

        <!--
            Firedown flame instead of the canonical download arrow —
            the static Downloads card below already owns that glyph,
            and the alpha-pulse animator (wired in HomeFragment)
            communicates 'live, happening now' in a way a duplicated
            download icon couldn't.
            Wrapped in a 40dp transparent slot to match the leading
            slot the Downloads / Safe Folder shelf cards use for
            their tonal chip — keeps icon centres and text columns
            aligned across the four home cards.
        -->
        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/active_download_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_firedown"
                app:tint="?attr/colorOnPrimaryContainer" />

        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <!--
                Section header — uppercase label so the card
                self-identifies. HomeFragment swaps in the
                'Downloading · +N more' variant when extras exist.
            -->
            <TextView
                android:id="@+id/active_download_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.08"
                android:text="@string/downloading"
                android:textAllCaps="true"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textColor="?attr/colorOnPrimaryContainer"
                tools:text="DOWNLOADING · +2 MORE" />

            <TextView
                android:id="@+id/active_download_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                android:textColor="?attr/colorOnPrimaryContainer"
                tools:text="my_video_file_name.mp4" />

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/active_download_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                app:indicatorColor="?attr/colorOnPrimaryContainer"
                app:indicatorTrackGapSize="0dp"
                app:trackCornerRadius="2dp"
                app:trackStopIndicatorSize="0dp" />

        </LinearLayout>

        <!--
            Percent (or 'Pending…' / live byte-size) lives in a 44dp
            trailing slot — same width as the media card's play/pause
            toggle so the two strips share a right-edge anchor when
            stacked. gravity=center keeps the text centred under the
            slot regardless of '5%' vs '100%' width.
        -->
        <TextView
            android:id="@+id/active_download_percent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:gravity="center"
            android:minWidth="44dp"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnPrimaryContainer"
            tools:text="45%" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
