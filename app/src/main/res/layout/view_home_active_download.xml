<?xml version="1.0" encoding="utf-8"?>
<!--
  Active-download strip on the home page. Shows the single newest
  in-flight regular download — if more are queued, a '+N more' suffix
  on the header surfaces the count without expanding the card.

  Three-column layout mirrors the playing-media strip below: pulsing
  Firedown flame (40dp slot) | text column (label + filename +
  LinearProgressIndicator) | percent (44dp trailing slot). The percent
  sits in the same horizontal position as the media card's play/pause
  toggle so the two 'live state' cards line up vertically when stacked.

  Tinted with colorPrimaryContainer to read as 'live' — distinct from
  the surface-container colour the static Downloads / Safe Folder cards
  use. Whole card is tappable; tap → DownloadsActivity.
-->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/active_download_strip"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clickable="true"
    android:focusable="true"
    android:visibility="gone"
    app:cardBackgroundColor="?attr/colorPrimaryContainer"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="84dp"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp">

        <!--
            Firedown flame instead of the canonical download arrow —
            the static Downloads card below already owns that glyph,
            and the alpha-pulse animator (wired in HomeFragment)
            communicates 'live, happening now' in a way a duplicated
            download icon couldn't.
            Wrapped in a 40dp transparent slot to match the leading
            slot the Downloads / Safe Folder shelf cards use for
            their tonal chip — keeps icon centres and text columns
            aligned across the four home cards.
        -->
        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/active_download_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_firedown"
                app:tint="?attr/colorOnPrimaryContainer" />

        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <!--
                Section header / eyebrow. HomeFragment builds the text:
                "DOWNLOADING · 9%" (or · Pending / · Video for queued / live),
                and "· +N more" when extra downloads are queued. The metric
                lives here rather than on its own line so the card stays two
                text rows + bar with no orphaned percent line.
            -->
            <TextView
                android:id="@+id/active_download_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:letterSpacing="0.08"
                android:maxLines="1"
                android:text="@string/downloading"
                android:textAllCaps="true"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textColor="?attr/colorOnPrimaryContainer"
                tools:text="DOWNLOADING · 9%" />

            <TextView
                android:id="@+id/active_download_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                android:textColor="?attr/colorOnPrimaryContainer"
                tools:text="my_video_file_name.mp4" />

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/active_download_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:indicatorColor="?attr/colorOnPrimaryContainer"
                app:indicatorTrackGapSize="0dp"
                app:trackCornerRadius="2dp"
                app:trackStopIndicatorSize="0dp" />

        </LinearLayout>

        <!--
            Cancel button — aborts the in-flight download (and removes its
            partial file) without leaving Home. Sits in the trailing slot the
            percent number used to occupy, so it shares a right-edge anchor
            with the media card's play/pause toggle when the strips stack.
            Borderless so it reads as an icon action on the tinted card; the
            click is wired separately from the card-body tap (which still
            opens Downloads) in HomeFragment.
        -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/active_download_cancel"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cancel"
            android:scaleType="centerInside"
            android:src="@drawable/ic_baseline_close_24"
            app:tint="?attr/colorOnPrimaryContainer" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
