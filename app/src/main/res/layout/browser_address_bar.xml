<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/address_bar_holder"
    android:layout_width="match_parent"
    android:background="?android:attr/colorBackground"
    android:layout_height="@dimen/address_bar_height">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/address_bar_background"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginHorizontal="8dp"
        android:background="@drawable/address_bar"
        android:elevation="0dp"
        android:importantForAccessibility="no"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_goneMarginStart="12dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/security_button"
        style="@style/Widget.Material3.Button.IconButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center_vertical"
        android:layout_marginStart="2dp"
        android:elevation="0dp"
        android:gravity="center"
        android:importantForAccessibility="no"
        android:insetLeft="0dp"
        android:insetTop="0dp"
        android:insetRight="0dp"
        android:insetBottom="0dp"
        android:minWidth="48dp"
        android:minHeight="48dp"
        android:padding="0dp"
        app:elevation="0dp"
        app:icon="@drawable/ic_shield_24"
        app:iconGravity="textTop"
        app:iconPadding="0dp"
        app:iconSize="@dimen/app_bar_icon_size"
        app:iconTint="?attr/colorOnSurface"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@id/address_bar_background"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearance="@style/ShapeAppearanceOverlay.Button.Circle" />


    <com.solarized.firedown.autocomplete.AutoCompleteEditText
        android:id="@+id/edit_text"
        android:layout_width="0dp"
        android:layout_height="@dimen/address_bar_height"
        android:layout_gravity="center"
        android:background="@null"
        android:hint="@string/browser_enter_url"
        android:imeOptions="actionGo"
        android:inputType="textWebEditText"
        android:textColor="?attr/colorOnSurface"
        android:textColorHighlight="@color/md_theme_inversePrimary"
        android:textColorHint="?attr/colorOnSurface"
        android:textSize="14.5sp"
        android:maxLines="1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/action_edit"
        app:layout_constraintStart_toEndOf="@id/security_button"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_goneMarginEnd="16dp"
        app:layout_goneMarginStart="16dp"
        app:layout_goneMarginTop="8dp" />


    <LinearLayout
        android:id="@+id/action_edit"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_marginEnd="4dp"
        android:minWidth="8dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/address_bar_background"
        app:layout_constraintTop_toTopOf="parent">


        <TextView
            android:id="@+id/search_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="8dp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/search_up"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:importantForAccessibility="no"
            android:nextFocusLeft="@id/search_up"
            android:stateListAnimator="@null"
            android:visibility="gone"
            app:elevation="0dp"
            app:icon="@drawable/keyboard_arrow_up_24"
            app:iconSize="20dp"
            app:iconTint="?attr/colorOnSurface"
            app:shapeAppearance="@style/ShapeAppearanceOverlay.Button.Circle" />


        <com.google.android.material.button.MaterialButton
            android:id="@+id/search_down"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:importantForAccessibility="no"
            android:stateListAnimator="@null"
            android:visibility="gone"
            app:elevation="0dp"
            app:icon="@drawable/keyboard_arrow_down_24"
            app:iconSize="20dp"
            app:iconTint="?attr/colorOnSurface"
            app:shapeAppearance="@style/ShapeAppearanceOverlay.Button.Circle" />


        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/clear_button"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:importantForAccessibility="no"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:nextFocusRight="@id/clear_button"
                android:padding="@dimen/button_icons_padding"
                android:stateListAnimator="@null"
                android:visibility="gone"
                app:elevation="0dp"
                app:icon="@drawable/ic_baseline_cancel_filled_24"
                app:iconSize="@dimen/app_bar_icon_size"
                app:iconTint="?attr/colorOnSurface"
                app:shapeAppearance="@style/ShapeAppearanceOverlay.Button.Circle" />


            <com.google.android.material.button.MaterialButton
                android:id="@+id/reload_button"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center_vertical"
                android:elevation="0dp"
                android:gravity="center"
                android:importantForAccessibility="no"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:padding="0dp"
                app:elevation="0dp"
                app:icon="@drawable/ic_refresh_24"
                app:iconSize="24dp"
                app:iconGravity="textTop"
                app:iconPadding="0dp"
                app:iconTint="?attr/colorOnSurface"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="@id/address_bar_background"
                app:layout_constraintTop_toTopOf="parent"
                app:shapeAppearance="@style/ShapeAppearanceOverlay.Button.Circle" />

        </FrameLayout>


    </LinearLayout>


    <com.solarized.firedown.geckoview.GeckoProgressBar
        android:id="@+id/progress_bar"
        style="@style/Base.Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="@dimen/progress_bar_height"
        android:elevation="@dimen/progress_bar_elevation"
        android:progressDrawable="@drawable/progress_bar_horizontal"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>
