<?xml version="1.0" encoding="utf-8"?>
<!--
    Home "more" popup sheet — slimmer sibling of the Browser popup.

    Same MaterialCard + 32dp neutral chip vocabulary as the browser
    popup, but with no quick-row (nothing page-contextual on Home)
    and a much smaller set of rows: only items that don't already
    have a surface on Home (cards or bottom-bar slots) live here.

    Sections:
      • Library / app — History, Settings
      • Destructive   — Quit Firedown (only visible when
                        SETTINGS_QUIT_PREF is on)

    Incognito home reuses this layout: the fragment swaps the History
    row over to Downloads (icon + label + dispatched id), since
    incognito home lacks a Downloads card and the History destination
    is irrelevant under private browsing.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <include
        layout="@layout/dialog_drag_handle" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="14dp">


            <!-- ── Section: Library / app ───────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardBackgroundColor="?attr/colorSurfaceContainer"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!--
                        History row. In incognito, the fragment swaps
                        the icon, label, and dispatched OptionEntity id
                        over to Downloads — incognito home lacks a
                        Downloads card and History is irrelevant under
                        private browsing.
                    -->
                    <LinearLayout
                        android:id="@+id/popup_history"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="10dp">

                        <FrameLayout
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_popup_chip_neutral">

                            <androidx.appcompat.widget.AppCompatImageView
                                android:id="@+id/popup_history_icon"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_history_24"
                                app:tint="?attr/colorOnSurfaceVariant" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/popup_history_label"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:text="@string/library_history"
                            android:textAppearance="?attr/textAppearanceTitleSmall"
                            android:textColor="?attr/colorOnSurface" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/popup_settings"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="10dp">

                        <FrameLayout
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_popup_chip_neutral">

                            <androidx.appcompat.widget.AppCompatImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_settings_24"
                                app:tint="?attr/colorOnSurfaceVariant" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:text="@string/browser_menu_settings"
                            android:textAppearance="?attr/textAppearanceTitleSmall"
                            android:textColor="?attr/colorOnSurface" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>


            <!-- ── Section: Destructive ─────────────────────────────── -->
            <!--
                Quit Firedown — same destructive treatment as the
                Browser popup. GONE unless SETTINGS_QUIT_PREF is on;
                the fragment toggles visibility at inflation time.
            -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/popup_quit_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:cardBackgroundColor="?attr/colorSurfaceContainer"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                tools:visibility="visible">

                <LinearLayout
                    android:id="@+id/popup_quit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="10dp">

                    <FrameLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_popup_chip_error">

                        <androidx.appcompat.widget.AppCompatImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_logout_24"
                            app:tint="?attr/colorOnErrorContainer" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:text="@string/delete_browsing_data_on_quit_action"
                        android:textAppearance="?attr/textAppearanceTitleSmall"
                        android:textColor="?attr/colorError" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
