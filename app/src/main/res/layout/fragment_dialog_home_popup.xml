<?xml version="1.0" encoding="utf-8"?>
<!--
    Home "more" popup sheet.

    Card removed, rows sit flat on the sheet surface. No section
    rules — with only two-or-three rows the structure is obvious,
    and the destructive Quit row marks itself via colorPrimary
    text + tint.

    Incognito home reuses this layout: the fragment swaps the History
    row's icon, label, and dispatched id over to Downloads.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="8dp">

    <include
        layout="@layout/dialog_drag_handle" />


    <!-- History. Fragment repaints drawableStart + label to
         Downloads under incognito. -->
    <LinearLayout
        android:id="@+id/popup_history"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <TextView
            android:id="@+id/popup_history_text"
            style="@style/TextAppearance.Material3.TitleMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:drawablePadding="16dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/library_history"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="15sp"
            app:drawableStartCompat="@drawable/ic_history_24"
            app:drawableTint="?attr/colorOnSurfaceVariant" />

    </LinearLayout>


    <!-- Settings. -->
    <LinearLayout
        android:id="@+id/popup_settings"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <TextView
            style="@style/TextAppearance.Material3.TitleMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:drawablePadding="16dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/browser_menu_settings"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="15sp"
            app:drawableStartCompat="@drawable/ic_settings_24"
            app:drawableTint="?attr/colorOnSurfaceVariant" />

    </LinearLayout>


    <!-- Destructive Quit — GONE unless SETTINGS_QUIT_PREF is on.
         colorPrimary text + drawable tint is what differentiates it. -->
    <LinearLayout
        android:id="@+id/popup_quit"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            style="@style/TextAppearance.Material3.TitleMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:drawablePadding="16dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/delete_browsing_data_on_quit_action"
            android:textColor="?attr/colorPrimary"
            android:textSize="15sp"
            app:drawableStartCompat="@drawable/ic_logout_24"
            app:drawableTint="?attr/colorPrimary" />

    </LinearLayout>

</LinearLayout>
