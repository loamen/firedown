<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/gif_maker_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:theme="@style/ThemeOverlay.FireDown.Toolbar"
            app:title="@string/gif_maker_title"
            app:navigationIcon="@drawable/ic_arrow_back_24"
            app:navigationIconTint="?attr/colorOnSurface" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="com.google.android.material.appbar.AppBarLayout$ScrollingViewBehavior">

        <!-- Player gets all the leftover height between toolbar and the
             trim controls. Custom controller keeps it to play/pause only. -->
        <androidx.media3.ui.PlayerView
            android:id="@+id/player_view"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@android:color/black"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/range_label"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:resize_mode="fit"
            app:show_subtitle_button="false"
            app:show_shuffle_button="false"
            app:show_buffering="never"
            app:controller_layout_id="@layout/exo_player_control_view_minimal"
            app:surface_type="texture_view" />

        <TextView
            android:id="@+id/range_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:textColor="?attr/colorOnSurface"
            app:layout_constraintBottom_toTopOf="@id/range_slider"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="00:00 → 00:30 (30s)" />

        <com.google.android.material.slider.RangeSlider
            android:id="@+id/range_slider"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:valueFrom="0"
            android:valueTo="100"
            android:stepSize="1"
            app:layout_constraintBottom_toTopOf="@id/playhead_indicator"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- A thin progress line visualises the playhead within the
             trim range as the live-preview loop runs. Uses the slider's
             horizontal padding so the indicator track aligns visually
             with the slider's track. -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/playhead_indicator"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="32dp"
            app:indicatorColor="?attr/colorPrimary"
            app:trackColor="@android:color/transparent"
            app:trackThickness="2dp"
            app:layout_constraintBottom_toTopOf="@id/speed_header"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Header row: static label on the left, current selection on the
             right. The slider itself only shows tick stops and a thumb;
             the right-side TextView keeps the selected speed visible
             without forcing the user to drag to read the tooltip. -->
        <LinearLayout
            android:id="@+id/speed_header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            app:layout_constraintBottom_toTopOf="@id/speed_slider"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/gif_maker_speed_label"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                android:textColor="?attr/colorOnSurface" />

            <TextView
                android:id="@+id/speed_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                android:textColor="?attr/colorPrimary"
                tools:text="Medium" />

        </LinearLayout>

        <!-- 5-stop slider (0..4 → very slow / slow / medium / fast / very
             fast). tickVisible draws a dot at each stop so the discrete
             positions are obvious; the floating label is configured in
             code via a LabelFormatter. -->
        <com.google.android.material.slider.Slider
            android:id="@+id/speed_slider"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:valueFrom="0"
            android:valueTo="4"
            android:stepSize="1"
            android:value="2"
            app:tickVisible="true"
            app:layout_constraintBottom_toTopOf="@id/create_button"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/create_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:text="@string/gif_maker_create"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Sized to bottom system inset by the inset listener in
         GifMakerFragment, matching the navigation_scrim used by
         BaseFocusFragment for the downloads list. -->
    <View
        android:id="@+id/navigation_scrim"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_gravity="bottom"
        android:background="?android:attr/colorBackground" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
