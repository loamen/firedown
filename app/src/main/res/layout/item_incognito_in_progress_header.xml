<?xml version="1.0" encoding="utf-8"?>
<!--
  Header for DownloadFragment's RecyclerView, shown via
  IncognitoInProgressHeaderAdapter when vault (incognito-tab)
  downloads are in flight. Scrolls with the rest of the list
  (the ConcatAdapter places it at adapter position 0 above the
  paginated download entries).

  Lock icon + trailing chevron: the card taps into the Vault, so the
  lock maps to the destination and the chevron marks it as forward
  navigation rather than a passive info row. No progress bar — this
  adapter only has a count (TaskViewModel#getSafeCount), not per-download
  progress, so a determinate bar is impossible and an averaged one would
  mislead. The cardBackgroundColor below is a fallback; the adapter
  overrides it at bind time with the SelectionStyling brand wash
  (primaryContainer @ 20% over surface).
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/list_spacing"
    android:layout_marginTop="@dimen/list_spacing"
    android:layout_marginBottom="@dimen/incognito_banner_margin_bottom"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="?attr/colorSurfaceContainerHighest">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/incognito_in_progress_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_lock_24"
            app:tint="?attr/colorOnSurface"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/incognito_in_progress_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:textColor="?attr/colorOnSurface"
            app:layout_constraintStart_toEndOf="@id/incognito_in_progress_icon"
            app:layout_constraintEnd_toStartOf="@id/incognito_in_progress_chevron"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="2dp"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurface"
            android:alpha="0.8"
            android:text="@string/incognito_downloads_in_progress_subtitle"
            app:layout_constraintStart_toEndOf="@id/incognito_in_progress_icon"
            app:layout_constraintEnd_toStartOf="@id/incognito_in_progress_chevron"
            app:layout_constraintTop_toBottomOf="@id/incognito_in_progress_title" />

        <!-- Trailing chevron — signals the whole card navigates forward
             (into the Vault). Decorative; the card itself carries the click. -->
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/incognito_in_progress_chevron"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="12dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_chevron_right_24"
            app:tint="?attr/colorOnSurfaceVariant"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
