<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:descendantFocusability="beforeDescendants"
    android:focusableInTouchMode="true">


    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:liftOnScroll="false">

        <com.solarized.firedown.geckoview.GeckoToolbar
            android:id="@+id/toolbar_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            app:enableHome="true" />

    </com.google.android.material.appbar.AppBarLayout>


    <androidx.core.widget.NestedScrollView
        android:id="@+id/home_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="@dimen/app_bar_size"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_behavior="com.google.android.material.appbar.AppBarLayout$ScrollingViewBehavior">

        <!--
            Stack spacing model: a single 4dp paddingTop on the column
            provides the gap from the toolbar to whichever card lands
            first. Each card carries its own marginBottom for the gap
            below it — so when a card is GONE neither its top nor its
            bottom margin contributes, and the next visible card sits
            4dp under the toolbar regardless of which one it is.
            Using marginTop instead would 'inherit' a 12dp top gap
            onto the new first card and push it down too far.
        -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="6dp"
            tools:visibility="visible">


            <com.solarized.firedown.ui.OnBoardingCard
                android:id="@+id/onboarding"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="top"
                android:layout_marginBottom="12dp" />


            <include
                android:id="@+id/active_download_strip"
                layout="@layout/view_home_active_download"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/list_spacing"
                android:layout_marginEnd="@dimen/list_spacing"
                android:layout_marginBottom="12dp" />


            <include
                android:id="@+id/home_media_strip"
                layout="@layout/view_home_media_strip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/list_spacing"
                android:layout_marginEnd="@dimen/list_spacing"
                android:layout_marginBottom="12dp" />


            <include
                android:id="@+id/recent_downloads_card"
                layout="@layout/card_home_recent_downloads"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/list_spacing"
                android:layout_marginEnd="@dimen/list_spacing"
                android:layout_marginBottom="12dp" />


            <!--
                Safe Folder entry card. Mirrors the Downloads card shape
                (surface-container background, icon + title + subtitle)
                so the two read as a pair. Subtitle reads 'N items saved'
                only when count > 0; otherwise title-only so a
                vault-curious user sees the entry name without a
                misleading '0 items'. Tap → VaultActivity (app-lock
                gate handles PIN / biometric).
            -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/home_vault_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/list_spacing"
                android:layout_marginEnd="@dimen/list_spacing"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp">

                    <FrameLayout
                        android:id="@+id/home_vault_chip"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_icon_container_tertiary">

                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/home_vault_icon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_lock_24"
                            app:tint="?attr/colorOnTertiaryContainer" />

                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/home_vault_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/home_vault_button"
                            android:textAppearance="?attr/textAppearanceTitleSmall"
                            android:textColor="?attr/colorOnSurface" />

                        <TextView
                            android:id="@+id/home_vault_subtitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:visibility="gone"
                            tools:text="12 items saved"
                            tools:visibility="visible" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>


        </LinearLayout>

    </androidx.core.widget.NestedScrollView>


    <com.solarized.firedown.autocomplete.AutoCompleteView
        android:id="@+id/auto_complete_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:elevation="@dimen/autocomplete_elevation"
        android:focusable="true"
        app:layout_behavior="com.google.android.material.appbar.AppBarLayout$ScrollingViewBehavior" />

    <FrameLayout
        android:id="@+id/bottom_new_tab"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="bottom"
        android:layout_marginTop="@dimen/app_bar_size"
        android:layout_marginBottom="@dimen/app_bar_size"
        android:background="?attr/colorSurfaceContainerLow"
        android:visibility="gone" />

    <com.solarized.firedown.geckoview.toolbar.BottomNavigationBar
        android:id="@+id/bottom_app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:enableCradle="false" />

    <View
        android:id="@+id/navigation_scrim"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_gravity="bottom"
        android:background="?android:attr/colorBackground" />


</androidx.coordinatorlayout.widget.CoordinatorLayout>