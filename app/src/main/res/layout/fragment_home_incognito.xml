<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/coordinator_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/incognito_surface"
    android:descendantFocusability="beforeDescendants"
    android:focusableInTouchMode="true">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/incognito_surface"
        app:liftOnScroll="false">

        <com.solarized.firedown.geckoview.GeckoToolbar
            android:id="@+id/toolbar_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            app:enableHome="true" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable content area -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="com.google.android.material.appbar.AppBarLayout$ScrollingViewBehavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <!-- Anchor the content to the upper area rather than the vertical
                 centre: the mascot that used to balance the top moved to the
                 incognito tabs empty state, so a fixed gap under the search bar
                 + a bottom spacer reads better than floating it mid-screen. -->

            <!-- Title -->
            <TextView
                android:id="@+id/incognito_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:text="@string/incognito_home_title"
                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                android:textColor="@color/incognito_on_surface" />

            <!-- Three facts: the only things that matter in private mode —
                 no history, no cookies, and where downloads land. Each is an
                 icon chip + one-line explainer; replaces the old four
                 overlapping bullets and adds the Safe-Folder behaviour. -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:orientation="vertical">

                <!-- No history -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_incognito_chip"
                        android:backgroundTint="@color/incognito_chip_history">

                        <androidx.appcompat.widget.AppCompatImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_history_24"
                            app:tint="@color/incognito_secondary_container" />

                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/incognito_fact_history_title"
                            android:textAppearance="?attr/textAppearanceTitleSmall"
                            android:textColor="@color/incognito_on_surface" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"
                            android:text="@string/incognito_fact_history_sub"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/incognito_on_surface_variant" />

                    </LinearLayout>

                </LinearLayout>

                <!-- No cookies -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:baselineAligned="false"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_incognito_chip"
                        android:backgroundTint="@color/incognito_chip_cookies">

                        <androidx.appcompat.widget.AppCompatImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/cookie_24"
                            app:tint="@color/incognito_primary_container" />

                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/incognito_fact_cookies_title"
                            android:textAppearance="?attr/textAppearanceTitleSmall"
                            android:textColor="@color/incognito_on_surface" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"
                            android:text="@string/incognito_fact_cookies_sub"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/incognito_on_surface_variant" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Downloads → Safe Folder -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:baselineAligned="false"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_incognito_chip"
                        android:backgroundTint="@color/incognito_chip_downloads">

                        <androidx.appcompat.widget.AppCompatImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_lock_24"
                            app:tint="@color/incognito_fact_downloads_icon" />

                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/incognito_fact_downloads_title"
                            android:textAppearance="?attr/textAppearanceTitleSmall"
                            android:textColor="@color/incognito_on_surface" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"
                            android:text="@string/incognito_fact_downloads_sub"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/incognito_on_surface_variant" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- Honest caveat: private mode is not invisibility. Reuses the
                 existing (already-translated) warning string. -->
            <TextView
                android:id="@+id/incognito_warning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="@string/incognito_home_warning"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="@color/incognito_on_surface_variant"
                android:lineSpacingMultiplier="1.3" />

            <!-- Spacer to push content toward center -->
            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Autocomplete overlay (same as HomeFragment) -->
    <com.solarized.firedown.autocomplete.AutoCompleteView
        android:id="@+id/auto_complete_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:elevation="@dimen/autocomplete_elevation"
        android:focusable="true"
        app:layout_behavior="com.google.android.material.appbar.AppBarLayout$ScrollingViewBehavior" />

    <!-- New tab flash overlay (same as HomeFragment) -->
    <FrameLayout
        android:id="@+id/bottom_new_tab"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="bottom"
        android:layout_marginTop="@dimen/app_bar_size"
        android:layout_marginBottom="@dimen/app_bar_size"
        android:background="@color/incognito"
        android:visibility="gone" />

    <!-- Bottom navigation bar -->
    <com.solarized.firedown.geckoview.toolbar.BottomNavigationBar
        android:id="@+id/bottom_app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:hideMiddleSlot="false" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>