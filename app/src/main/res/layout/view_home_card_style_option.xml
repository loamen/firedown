<?xml version="1.0" encoding="utf-8"?>
<!--
  One row in the home-cards style picker. Radio + name on top,
  miniature previews of the two shelf cards (Downloads, Safe Folder)
  below, divider at the bottom. The active-download + playing-media
  cards are intentionally not previewed here — they keep their
  branded surface across variants 0–3 (only Ember darkens them),
  and rendering them five times in the picker would just be
  repetition. HomeCardStylesFragment inflates one of these per
  HomeCardStyle.ALL and rebinds the preview colours through
  HomeCardStyle.applyToCard so what the user sees in the picker
  matches what HomeFragment renders after selection.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <RadioButton
            android:id="@+id/style_option_radio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="false"
            android:focusable="false" />

        <TextView
            android:id="@+id/style_option_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:textColor="?attr/colorOnSurface" />

    </LinearLayout>

    <!-- ── Downloads card preview ─────────────────────────────── -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/style_option_downloads_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="10dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp">

            <FrameLayout
                android:id="@+id/style_option_downloads_chip"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_icon_container_primary">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/style_option_downloads_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/download_24" />

            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/style_option_downloads_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/navigation_downloads"
                    android:textAppearance="?attr/textAppearanceTitleSmall" />

                <TextView
                    android:id="@+id/style_option_downloads_subtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/home_card_style_preview_downloads_subtitle"
                    android:textAppearance="?attr/textAppearanceBodySmall" />

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- ── Safe Folder card preview ───────────────────────────── -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/style_option_vault_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp">

            <FrameLayout
                android:id="@+id/style_option_vault_chip"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_icon_container_tertiary">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/style_option_vault_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_lock_24" />

            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/style_option_vault_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/home_vault_button"
                    android:textAppearance="?attr/textAppearanceTitleSmall" />

                <TextView
                    android:id="@+id/style_option_vault_subtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/home_card_style_preview_vault_subtitle"
                    android:textAppearance="?attr/textAppearanceBodySmall" />

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginHorizontal="16dp"
        android:background="?attr/colorOutlineVariant" />

</LinearLayout>
