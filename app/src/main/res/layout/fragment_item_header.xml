<?xml version="1.0" encoding="utf-8"?>
<!--
  Section header row for the downloads list. Pure typographic label
  on a transparent surface — title + aggregate subtitle, no card
  chrome, no divider line, no chevron. The section break reads
  through vertical whitespace and a subtle weight/color contrast
  against the download rows beneath it.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="@dimen/list_spacing"
    android:paddingEnd="@dimen/list_spacing"
    android:paddingTop="20dp"
    android:paddingBottom="6dp">

    <TextView
        android:id="@+id/item_header"
        style="@style/TextAppearance.Material3.LabelLarge"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:singleLine="true"
        android:textColor="?attr/colorOnSurface"
        tools:text="kick.com" />

    <TextView
        android:id="@+id/item_header_subtitle"
        style="@style/TextAppearance.Material3.BodySmall"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:singleLine="true"
        android:textColor="?attr/colorOnSurfaceVariant"
        tools:text="41 files · 383.9 kB" />

</LinearLayout>
